# AWS credentials for bench-infra. Copy to `.env` (gitignored) and fill in.
# The Makefile auto-loads .env and exports these into terraform/ansible.
# Use bare KEY=value (no spaces around '='). Quotes are tolerated for the cred
# vars below (stripped), but bare is preferred — `make`'s .env include keeps
# quotes literally, unlike shell dotenv loaders.
#
# Use a SCOPED IAM principal (see aws-iam-bench-policy.json), NOT root keys.

# --- Option A: static keys ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...        # only for temporary/STS credentials

# --- Option B: a named profile from ~/.aws/credentials ---
# AWS_PROFILE=bench
